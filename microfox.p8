musics={
	chill=0,
	coq=17,
}
cur_msq=99

lvl=0
lst_act=0
gam_stp=.2
anm_stp=16
jmp_hgt=4
fle_dst=3

-->8
function play_music(msq)
	if cur_msq~=msq then
		cur_msq=msq
		music(msq)
	end
end

function next_level()
	lvl=(lvl+1)%#lvls
	load_level(lvl)
	sfx(59)
end

function reset_level()
	load_level(lvl)
end

function load_level(n)
	local lvl_e={}
	for dat_e in all(lvls[n+1].e) do
		add(lvl_e, new_entity(dat_e))
	end

	coop={
		m=lvls[n+1].m,
		b={unpack(lvls[n+1].b)},
		e=lvl_e,
		h=lvls[n+1].h,
		q=lvls[n+1].q,
	}
	
	play_music(musics.chill)
end

function same_pos(e1,e2)
 return e1.x==e2.x and e1.y==e2.y
end

function check_lose()
	if not check_spawn_coq() then
		return false
	end

	local foxes=get_entities(e_ids.fox)
	local coqs=get_entities(e_ids.coq)
	
	for fox in all(foxes) do
		for coq in all(coqs) do
			if same_pos(fox,coq) then
				return true
			end
			if same_pos(fox,{coq.lst_x,coq.lst_y}) then
				return true
			end
		end
	end
	
	return false
end

function check_win()
	if not check_spawn_hole() then
		return false
	end

	local foxes=get_entities(e_ids.fox)
	local holes=get_entities(e_ids.hol)
	
	for fox in all(foxes) do
		for hole in all(holes) do
			if fox.x==hole.x and fox.y==hole.y then
				return true
			end
		end
	end
	
	return false
end

function eat_chk()
	local foxes=get_entities(e_ids.fox)
	local chickens=get_entities(e_ids.chk)

	for fox in all(foxes) do
		for chk in all(chickens) do
			if same_pos(fox,chk) then
				del(coop.e, chk)
				sfx(58)
			end
		end
	end
end

function check_spawn_hole()
	local chickens=get_entities(e_ids.chk)
	
	if #chickens>coop.h then
		return false
	end
	return true
end

function check_spawn_coq()
	local chickens=get_entities(e_ids.chk)
	
	if #chickens>coop.q then
		return false
	end
	return true
end

function up_mv()
	local lst=time()
	local mov={
		x=0,
		y=0,
		d=0,
		a=0,
		wait=false,
	}

	if (btn(⬅️)) then
		mov.x=-1
		mov.d=-1
	elseif (btn(➡️)) then
		mov.x=1
		mov.d=1
	elseif (btn(⬆️)) then
		mov.y=-1
		mov.a=-1
	elseif (btn(⬇️)) then
		mov.y=1
		mov.a=1
	elseif (btn(❎)) then
		reset_level()
	elseif (btn(🅾️)) then
		mov.wait=true
	end
	
	if gam_stp<(lst-lst_act) then
		if check_lose() then
			sfx(57)
			reset_level()
			return
		end
		if check_spawn_coq() then
			play_music(musics.coq)
		end
		if check_win() then
			next_level()
			return
		end
		eat_chk()
		up_e()
		local fox_mov=mv_fox(mov)
		if fox_mov.moved then
			mv_chk(fox_mov.fmvs)
			mv_coq(fox_mov.fmvs)
		end
	end
end

function up_e()
	for e in all(coop.e) do
		e.lst_x=e.x
		e.lst_y=e.y
		e.f=false
		e.wait=false
	end
end

function up_ge()
	for e in all(coop.e) do
		e.t=(flr(time()*4))%#e.s
	end
end

function draw_lvl()
	map(
		coop.m.cx,
		coop.m.cy,
		coop.m.sx,
		coop.m.sy,
		coop.m.cw,
		coop.m.ch
	)
	for i=0,7 do
		for j=0,7 do
			spr(
				b_data[coop.b[j+1][i+1]],
				i*16,j*16,2,2
			)
		end
	end
end

function draw_entities()
	local lst=time()
	local dif=lst-lst_act
	
	for e in all(coop.e) do
		if e.id==e_ids.hol then
			if not check_spawn_hole() then
				goto drawnextentity
			end
			spr(
				e.s[e.t+1],
				e.x*16,e.y*16,
				e.sw,e.sh
			)//entity
			goto drawnextentity
		end
		if e.id==e_ids.coq then
			if not check_spawn_coq() then
				goto drawnextentity
			end
		end
		local ax=dif/gam_stp*16*e.d
		local ay=dif/gam_stp*16*e.a
		if e.lst_x==e.x then
		 ax=0
		end
		if e.lst_y==e.y then
			ay=0
		end
		local jump=sin(dif/gam_stp/2)*jmp_hgt
		if e.lst_x==e.x and e.lst_y==e.y and not e.wait then
			jump=0
		end
		if e.f then
			ax=sin(dif/gam_stp*2)*2
		end
	
		spr(
			e.shdw,
			e.lst_x*16+ax,e.lst_y*16+ay,
			e.sw,e.sh,
			e.d~=-1
		)//shadow
		spr(
			e.s[e.t+1],
			e.lst_x*16+ax,e.lst_y*16+ay+jump,
			e.sw,e.sh,
			e.d~=-1
		)//entity
		
		if e.lst_x==0 and e.x==7 then
			spr(
				e.s[e.t+1],
				8*16+ax,e.lst_y*16+ay+jump,
				e.sw,e.sh,
				e.d~=-1
			)//entity crossing
		end
		if e.lst_x==7 and e.x==0 then
			spr(
				e.s[e.t+1],
				-1*16+ax,e.lst_y*16+ay+jump,
				e.sw,e.sh,
				e.d~=-1
			)//entity crossing
		end
		if e.lst_y==0 and e.y==7 then
			spr(
				e.s[e.t+1],
				e.lst_x*16+ax,8*16+ay+jump,
				e.sw,e.sh,
				e.d~=-1
			)//entity crossing
		end
		if e.lst_y==7 and e.y==0 then
			spr(
				e.s[e.t+1],
				e.lst_x*16+ax,-1*16+ay+jump,
				e.sw,e.sh,
				e.d~=-1
			)//entity crossing
		end
		::drawnextentity::
	end
end

-->8
function moveable(new_pos,fbd)
	for fb in all(fbd) do
		if new_pos.x==fb.x and new_pos.y==fb.y then
			return false
		end
	end
	if coop.b[new_pos.y+1][new_pos.x+1]~=b_ids.air then
		return false
	end
	return true
end

function mv_fox(mov)
	local ret={
		moved=false,
		fmvs={}
	}

	if mov.x==0 and mov.y==0 and not mov.wait then
		return ret
	end
	
	lst_act=time()
	local foxes=get_entities(e_ids.fox)
	
	local coqs=get_entities(e_ids.coq)
	local cmvs={}
	if check_spawn_coq() then
		for coq in all(coqs) do
			add(cmvs, coq)
		end
	end
	
	for e in all(foxes) do
		add(ret.fmvs,{
			x=e.x,
			y=e.y
		})
		local res=mv_e(e,mov,cmvs)
		if res.moved then
			add(ret.fmvs,res)
		else
			e.f = true
			sfx(60)
		end
		ret.moved=true
	end
	return ret
end

function get_fmvs(fmvs)
	local new_fmvs={}
	for fmv in all(fmvs) do
		add(new_fmvs,{
			x=fmv.x,
			y=fmv.y,
		})
		add(new_fmvs,{
			x=(fmv.x+fle_dst)%8-fle_dst,
			y=(fmv.y+fle_dst)%8-fle_dst,
		})
		add(new_fmvs,{
			x=(fmv.x-fle_dst)%8+fle_dst,
			y=(fmv.y-fle_dst)%8+fle_dst,
		})
		add(new_fmvs,{
			x=(fmv.x+fle_dst)%8-fle_dst,
			y=(fmv.y-fle_dst)%8+fle_dst,
		})
		add(new_fmvs,{
			x=(fmv.x-fle_dst)%8+fle_dst,
			y=(fmv.y+fle_dst)%8-fle_dst,
		})
	end
	return new_fmvs
end

function mv_chk(fmvs)
	local chickens=get_entities(e_ids.chk)

	local new_fmvs=get_fmvs(fmvs)
	local nfmv=nil

	for e in all(chickens) do
		local min_fox=99
		for fmv in all(new_fmvs) do
			local dist=abs(abs(e.x-fmv.x)+abs(e.y-fmv.y))
			if dist==0 then
				goto skipfmv
			end
			if dist<min_fox then
				nfmv=fmv
				min_fox=dist
			end
			::skipfmv::
		end
		if min_fox>fle_dst then
			goto nextchkmove
		end
		local xdir=sgn(e.x-nfmv.x)
		local ydir=sgn(e.y-nfmv.y)
		if abs(e.x-nfmv.x)>abs(e.y-nfmv.y) then
			local xdr={
				x=xdir,y=0,
				d=xdir,a=0,
			}
			local ydr={
				x=0,y=ydir,
				d=0,a=ydir,
			}
			local up={
				x=0,y=-1,
				d=0,a=-1,
			}
			local dn={
				x=0,y=1,
				d=0,a=1,
			}
			local rt={
				x=1,y=0,
				d=1,a=0,
			}
			local lt={
				x=-1,y=0,
				d=-1,a=0,
			}
			if mv_e(e,xdr,new_fmvs).moved then
			elseif mv_e(e,ydr,new_fmvs).moved then
			elseif mv_e(e,up,new_fmvs).moved then
			elseif mv_e(e,dn,new_fmvs).moved then
			elseif mv_e(e,rt,new_fmvs).moved then
			elseif mv_e(e,lt,new_fmvs).moved then
			end
		else
			local ydr={
				x=0,y=ydir,
				d=0,a=ydir,
			}
			local xdr={
				x=xdir,y=0,
				d=xdir,a=0,
			}
			local rt={
				x=1,y=0,
				d=1,a=0,
			}
			local lt={
				x=-1,y=0,
				d=-1,a=0,
			}
			local up={
				x=0,y=-1,
				d=0,a=-1,
			}
			local dn={
				x=0,y=1,
				d=0,a=1,
			}
			if mv_e(e,ydr,new_fmvs).moved then
			elseif mv_e(e,xdr,new_fmvs).moved then
			elseif mv_e(e,rt,new_fmvs).moved then
			elseif mv_e(e,lt,new_fmvs).moved then
			elseif mv_e(e,up,new_fmvs).moved then
			elseif mv_e(e,dn,new_fmvs).moved then
			end
		end
		::nextchkmove::
	end
end

function mv_coq(fmvs)
	if not check_spawn_coq() then
		return
	end

	local coqs=get_entities(e_ids.coq)

	local new_fmvs=get_fmvs(fmvs)
	local nfmv=nil

	for e in all(coqs) do
		local min_fox=99
		for fmv in all(new_fmvs) do
			local dist=abs(abs(e.x-fmv.x)+abs(e.y-fmv.y))
			if dist==0 then
				goto skipfmv
			end
			if dist<min_fox then
				nfmv=fmv
				min_fox=dist
			end
			::skipfmv::
		end
		
		local xdir=sgn(e.x-nfmv.x)
		local ydir=sgn(e.y-nfmv.y)
		if abs(e.x-nfmv.x)>abs(e.y-nfmv.y) then
			local xdr={
				x=-xdir,y=0,
				d=-xdir,a=0,
			}
			local ydr={
				x=0,y=-ydir,
				d=0,a=-ydir,
			}
			local up={
				x=0,y=-1,
				d=0,a=-1,
			}
			local dn={
				x=0,y=1,
				d=0,a=1,
			}
			local rt={
				x=1,y=0,
				d=1,a=0,
			}
			local lt={
				x=-1,y=0,
				d=-1,a=0,
			}
			if mv_e(e,xdr,{}).moved then
			elseif mv_e(e,ydr,{}).moved then
			elseif mv_e(e,up,{}).moved then
			elseif mv_e(e,dn,{}).moved then
			elseif mv_e(e,rt,{}).moved then
			elseif mv_e(e,lt,{}).moved then
			end
		else
			local ydr={
				x=0,y=-ydir,
				d=0,a=-ydir,
			}
			local xdr={
				x=-xdir,y=0,
				d=-xdir,a=0,
			}
			local rt={
				x=1,y=0,
				d=1,a=0,
			}
			local lt={
				x=-1,y=0,
				d=-1,a=0,
			}
			local up={
				x=0,y=-1,
				d=0,a=-1,
			}
			local dn={
				x=0,y=1,
				d=0,a=1,
			}
			if mv_e(e,ydr,{}).moved then
			elseif mv_e(e,xdr,{}).moved then
			elseif mv_e(e,rt,{}).moved then
			elseif mv_e(e,lt,{}).moved then
			elseif mv_e(e,up,{}).moved then
			elseif mv_e(e,dn,{}).moved then
			end
		end
		::nextchkmove::
	end
end

function mv_e(e, mov, fbd)
	local new_pos={
		x=(e.x+mov.x)%8,
		y=(e.y+mov.y)%8,
		wait=mov.wait,
	}
	if mov.d~=0 then
		e.d=mov.d
	end
	if mov.a~=0 then
		e.a=mov.a
	end
	if not moveable(new_pos,fbd) then
		return {
			moved=false,
			x=-1,
			y=-1,
		}
	end
	e.x=new_pos.x
	e.y=new_pos.y
	e.wait=new_pos.wait
	sfx(62)
	return {
		moved=true,
		x=e.x,
		y=e.y,
	}
end

