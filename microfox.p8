function new_entity(dat_e)
	return {
		id=dat_e.id,
		shdw=e_data[dat_e.id].shdw,
		s={unpack(e_data[dat_e.id].s)},
		sw=e_data[dat_e.id].sw,
		sh=e_data[dat_e.id].sh,
		d=e_data[dat_e.id].d,
		a=e_data[dat_e.id].a,
		f=e_data[dat_e.id].f,
		
		t=0,
		x=dat_e.x,
		y=dat_e.y,
		lst_x=dat_e.x,
		lst_y=dat_e.y,
		wait=false,
	}
end

function get_entities(eid)
	local entities={}
	for e in all(coop.e) do
		if e.id==eid then
			add(entities, e)
		end
	end
	return entities
end

