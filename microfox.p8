pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function new_entity(s,f)
	return {
		sprite = s,
		flipped = f,
	}
end

coop = {}

function init_coop()
	for i=1,16 do
		coop[i] = {}
		for j=1,16 do
			coop[i][j] = new_entity(
				99,
				false
			)
		end
	end
end

function clear_coop()
	init_coop()
end

fox = {
	sprite={0,2},
	x=0,
	y=0,
	flipped=false,
}

function _init()
	palt(12,true)
	palt(0,false)
	
	init_coop()
end

function _update()
	last = time()

	if (btn(⬅️)) then
		fox.x = (fox.x-1)%8
		fox.flipped = false
	end
	if (btn(➡️)) then
		fox.x = (fox.x+1)%8
		fox.flipped = true
	end
	if (btn(⬆️)) then
		fox.y = (fox.y-1)%8
	end
	if (btn(⬇️)) then
		fox.y = (fox.y+1)%8
	end

	clear_coop()

	coop[fox.x+1][fox.y+1] =
		new_entity(
			fox.sprite[flr(last)%2+1],
			fox.flipped
		)
end

function _draw()
	cls()
	for i=0,7 do
		for j=0,7 do
			spr(
				coop[i+1][j+1].sprite,
				i*16,
				j*16,
				2,2,
				coop[i+1][j+1].flipped
			)
		end
	end
	print(flr(last)%2)
end
